/* pages/index/index.wxss */
.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 48rpx 28rpx 80rpx;
}

.title {
  color: #263238;
  font-size: 52rpx;
  font-weight: bold;
  text-align: center;
  letter-spacing: 8rpx;
}

.subtitle {
  margin: 14rpx 0 36rpx;
  color: #7a7467;
  font-size: 26rpx;
  text-align: center;
}

.card {
  margin-bottom: 28rpx;
  padding: 30rpx;
  background: #fffdf7;
  border: 1rpx solid #ded7c8;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 22rpx rgba(70, 60, 40, 0.08);
}

.realm {
  margin-bottom: 24rpx;
  padding-bottom: 22rpx;
  color: #8b4513;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  border-bottom: 1rpx solid #e8e0d1;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 13rpx 0;
  font-size: 29rpx;
}

.value {
  color: #9a5d20;
  font-weight: bold;
}

.main-button {
  margin-bottom: 28rpx;
  padding: 12rpx 0;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  background: #9a5d20;
}

.main-button:active {
  background: #774616;
}

.section-title {
  margin-bottom: 24rpx;
  color: #37474f;
  font-size: 32rpx;
  font-weight: bold;
}

.action-button,
.break-button,
.pill-button,
.adventure-button {
  color: #ffffff;
  font-size: 28rpx;
  background: #526d5b;
}

.action-button[disabled],
.break-button[disabled] {
  color: #999999;
  background: #dedbd3;
}

.tip {
  margin: 10rpx 0 28rpx;
  color: #8a857a;
  font-size: 24rpx;
  text-align: center;
}

.breakthrough-text {
  color: #5d4037;
  font-size: 30rpx;
  text-align: center;
}

.chance-text {
  margin: -14rpx 0 24rpx;
  color: #8b3a3a;
  font-size: 25rpx;
  text-align: center;
}

.break-button {
  background: #8b3a3a;
}

.pill-button {
  margin-top: 22rpx;
  background: #8b6b35;
}

.adventure-button {
  margin-top: 22rpx;
  background: #456b78;
}

.status-line {
  color: #9a5d20;
  font-size: 27rpx;
  text-align: center;
}

.status-line.muted {
  color: #8a857a;
}

.event-log {
  margin-top: 24rpx;
  padding: 20rpx;
  color: #625c50;
  font-size: 25rpx;
  line-height: 1.6;
  background: #f6f1e7;
  border-radius: 10rpx;
}

.finished {
  padding: 20rpx 0;
  color: #9a5d20;
  font-size: 28rpx;
  text-align: center;
}

.save-tip {
  color: #999386;
  font-size: 23rpx;
  text-align: center;
}
