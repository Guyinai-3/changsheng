<!-- pages/index/index.wxml -->
<view class="page">
  <view class="title">问道长生</view>
  <view class="subtitle">从一介凡人开始你的修仙之路</view>

  <!-- 游戏当前状态 -->
  <view class="card">
    <view class="realm">当前境界：{{realmName}}</view>

    <view class="row">
      <text>当前修为</text>
      <text class="value">{{cultivation}}</text>
    </view>
    <view class="row">
      <text>灵石</text>
      <text class="value">{{spiritStone}}</text>
    </view>
    <view class="row">
      <text>聚气丹</text>
      <text class="value">{{pillCount}} 枚</text>
    </view>
    <view class="row">
      <text>每次修炼</text>
      <text class="value">+{{effectiveClickPower}} 修为</text>
    </view>
    <view class="row">
      <text>自动修炼</text>
      <text class="value">+{{effectiveAutoPower}} 修为/秒</text>
    </view>
    <view class="row">
      <text>功法等级</text>
      <text class="value">{{skillLevel}} 级</text>
    </view>
    <view class="row">
      <text>聚灵阵等级</text>
      <text class="value">{{arrayLevel}} 级</text>
    </view>
  </view>

  <!-- 手动修炼 -->
  <button class="main-button" bindtap="cultivateOnce">
    修炼一次（+{{effectiveClickPower}}）
  </button>

  <!-- 聚气丹区域 -->
  <view class="card">
    <view class="section-title">丹药</view>
    <view class="status-line" wx:if="{{pillRemainingSeconds > 0}}">
      聚气丹生效中：剩余 {{pillRemainingSeconds}} 秒（收益 ×1.5）
    </view>
    <view class="status-line muted" wx:else>
      聚气丹当前未生效
    </view>
    <button class="pill-button" bindtap="usePill">
      使用聚气丹（现有 {{pillCount}} 枚）
    </button>
  </view>

  <!-- 升级区域 -->
  <view class="card">
    <view class="section-title">洞府建设</view>

    <button
      class="action-button"
      bindtap="upgradeSkill"
      disabled="{{cultivation < skillCost}}"
    >
      升级功法（消耗 {{skillCost}} 修为）
    </button>
    <view class="tip">升级后每次修炼增加 1 点修为</view>

    <button
      class="action-button"
      bindtap="upgradeArray"
      disabled="{{spiritStone < arrayCost}}"
    >
      升级聚灵阵（消耗 {{arrayCost}} 灵石）
    </button>
    <view class="tip">升级后每秒自动修炼增加 1 点修为</view>
  </view>

  <!-- 外出历练区域 -->
  <view class="card">
    <view class="section-title">外出历练</view>
    <view class="status-line" wx:if="{{adventureRemainingSeconds > 0}}">
      历练冷却：还剩 {{adventureRemainingSeconds}} 秒
    </view>
    <view class="status-line muted" wx:else>
      当前可以外出历练
    </view>
    <button class="adventure-button" bindtap="goAdventure">
      外出历练
    </button>
    <view class="event-log">最新见闻：{{adventureLog}}</view>
  </view>

  <!-- 突破区域 -->
  <view class="card">
    <view class="section-title">境界突破</view>

    <block wx:if="{{hasNextRealm}}">
      <view class="breakthrough-text">
        下一境界：{{nextRealmName}}
      </view>
      <view class="tip">突破需要 {{breakthroughCost}} 修为</view>
      <view class="chance-text">
        突破成功率：{{breakthroughChanceText}}
      </view>
      <button
        class="break-button"
        bindtap="breakthrough"
        disabled="{{cultivation < breakthroughCost}}"
      >
        突破境界
      </button>
    </block>

    <view wx:else class="finished">
      恭喜！你已达到当前版本的最高境界。
    </view>
  </view>

  <view class="save-tip">游戏会自动保存到微信本地存储</view>
</view>
